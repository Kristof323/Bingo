<Window x:Class="BingoGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bingó" Width="500" Height="550"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Button x:Name="GenerateButton"
                Grid.Row="0"
                Height="36"
                FontSize="14"
                Content="Kártya generálása"
                Click="GenerateButton_Click"/>

        <Label Grid.Row="1" 
               Content="bingo.txt" 
               Margin="0,12,0,4"
               FontSize="12"
               Foreground="#666"/>

        <Border Grid.Row="2" 
                Margin="0,4,0,16" 
                BorderBrush="#CCC" 
                BorderThickness="1" 
                Padding="10"
                Background="White">
            <UniformGrid x:Name="CardGrid" Rows="5" Columns="5"/>
        </Border>

        <TextBox x:Name="FileNameTextBox"
                 Grid.Row="3"
                 Height="32"
                 FontSize="14"
                 VerticalContentAlignment="Center"
                 Text="bingo.txt"/>

        <Button x:Name="SaveButton"
                Grid.Row="4"
                Height="36"
                Margin="0,12,0,0"
                FontSize="14"
                Content="Mentés"
                Click="SaveButton_Click"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,16,0,0">
            <TextBox x:Name="PlayerNameTextBox"
                     Width="200"
                     Height="32"
                     FontSize="14"
                     VerticalContentAlignment="Center"
                     Text="nevek.text"/>
            <Button x:Name="LoadPlayerListButton"
                    Width="120"
                    Height="32"
                    Margin="8,0,0,0"
                    FontSize="12"
                    Content="Nevek betöltése"
                    Click="LoadPlayerListButton_Click"/>
            <ComboBox x:Name="PlayerComboBox"
                      Width="120"
                      Height="32"
                      Margin="8,0,0,0"
                      FontSize="12"
                      SelectionChanged="PlayerComboBox_SelectionChanged"/>
        </StackPanel>
    </Grid>
</Window>
